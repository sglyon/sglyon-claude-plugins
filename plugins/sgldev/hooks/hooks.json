{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh $CLAUDE_PLUGIN_ROOT/hooks/scripts/uvrun.sh $CLAUDE_PLUGIN_ROOT/hooks/scripts/load_expertise.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "sh $CLAUDE_PLUGIN_ROOT/hooks/scripts/uvrun.sh $CLAUDE_PLUGIN_ROOT/hooks/scripts/inject_expertise.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "sh $CLAUDE_PLUGIN_ROOT/hooks/scripts/uvrun.sh $CLAUDE_PLUGIN_ROOT/hooks/scripts/validate_expertise.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
